# ─── DomicileDB operator configuration ───────────────────────────────────────
# Everything here is set by the OPERATOR at deploy/runtime. None of it is
# surfaced as an end-user setting. Copy to `.env` and fill in real values.
# NEVER commit `.env`.

# Where the app stores its SQLite db, media, and backups (mounted volume).
DATA_DIR=/data

# ─── AI Assist (OpenRouter) ──────────────────────────────────────────────────
# Remote AI is opt-in per action. Leave the key blank to disable AI features.
OPENROUTER_API_KEY=
# A vision-capable model id, e.g. openai/gpt-4o or anthropic/claude-3.5-sonnet
OPENROUTER_MODEL=openai/gpt-4o
# Override only for an OpenAI-compatible gateway (default is OpenRouter).
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─── Off-site backup (S3 / S3-compatible: AWS, MinIO, Backblaze B2, R2) ───────
# Leave S3_BUCKET blank to disable scheduled backups.
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# cron expression for scheduled backups (default: nightly at 03:00)
BACKUP_CRON=0 3 * * *

# ─── Coverage & valuation tuning ─────────────────────────────────────────────
# Fraction of the Coverage B limit at which the "approaching limit" nudge fires.
COVERAGE_WARN_PCT=0.80
# How many days before a replacement-cost value is considered stale (quarterly).
REVALUATION_CADENCE_DAYS=90

# ─── Security notice ─────────────────────────────────────────────────────────
# This app has NO built-in authentication. It MUST be deployed behind a trusted
# network boundary (VPN) and/or a reverse proxy that handles auth + HTTPS.
# HTTPS is required for PWA install, offline support, and live camera capture.
