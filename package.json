{
  "name": "domiciledb",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted home inventory built to prove what you owned and get paid after a disaster.",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/lib-storage": "^3.700.0",
    "@react-pdf/renderer": "^4.1.5",
    "better-sqlite3": "^12.2.0",
    "drizzle-orm": "^0.38.3",
    "lucide-react": "^0.468.0",
    "next": "15.5.19",
    "node-cron": "^3.0.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.54.2",
    "@hookform/resolvers": "^3.10.0",
    "sharp": "^0.33.5",
    "zod": "^3.24.1",
    "drizzle-zod": "^0.6.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "^1.49.1",
    "@serwist/next": "^9.0.11",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.17.0",
    "eslint-config-next": "15.5.19",
    "eslint-config-prettier": "^9.1.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "serwist": "^9.0.11",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=22"
  },
  "comments": {
    "overrides": "Pin @emnapi/* (optional+peer wasm deps from sharp/transitive) to consistent versions; works around an npm bug where the lockfile writer and `npm ci` validator disagree, which otherwise breaks `npm ci` in CI and Docker."
  },
  "overrides": {
    "@emnapi/wasi-threads": "1.2.2",
    "@emnapi/core": "1.10.0"
  }
}
